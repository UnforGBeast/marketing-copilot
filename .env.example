# -----------------------------------------------------------------------
# Core
# -----------------------------------------------------------------------
GOOGLE_API_KEY=your_gemini_api_key_here
ENVIRONMENT=development        # set to "production" for HSTS + stricter CORS

# -----------------------------------------------------------------------
# Security — MUST change before deploying
# -----------------------------------------------------------------------
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(64))"
SECRET_KEY=CHANGE_ME_USE_A_LONG_RANDOM_STRING

# -----------------------------------------------------------------------
# URLs
# -----------------------------------------------------------------------
FRONTEND_URL=http://localhost:8501
BACKEND_URL=http://localhost:8001   # used by the Streamlit frontend

# -----------------------------------------------------------------------
# Database (SQLite for dev, PostgreSQL for production)
# -----------------------------------------------------------------------
# Development (default — no config needed):
# DATABASE_URL=sqlite:///./marketing_copilot.db

# Production PostgreSQL example:
# DATABASE_URL=postgresql://user:password@localhost:5432/marketing_copilot

# -----------------------------------------------------------------------
# Stripe (get from https://dashboard.stripe.com/apikeys)
# -----------------------------------------------------------------------
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRO_PRICE_ID=price_...          # monthly Pro price ID from Stripe dashboard
STRIPE_ENTERPRISE_PRICE_ID=price_...   # monthly Enterprise price ID from Stripe dashboard
